    "@hiyve/core": "1.17.3",
    "@hiyve/react": "2.13.3",
    "@hiyve/react-room": "1.9.3",
    "@hiyve/react-ui": "1.12.3",
    "@hiyve/rtc-client": "1.52.4",
    "@hiyve/utilities": "1.43.3",
    "@mui/icons-material": "^5.15.0",
    "@mui/material": "^5.15.0",
    "@mui/system": "^5.18.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "jsdom": "^24.0.0",
    "@testing-library/react": "^14.2.0",
    "@testing-library/user-event": "^14.5.0",
    "@testing-library/jest-dom": "^6.4.0"

# Hiyve SDK Credentials — get these from console.hiyve.dev

# API Key (required for all Hiyve apps)
APIKEY=pk_test_xxx

# Client Secret (required for video conferencing — generates room tokens)
# Not needed for identity-only apps
CLIENT_SECRET=sk_test_xxx

# Server Configuration (optional — defaults shown)
SERVER_REGION=us-west-2
SERVER_REGION_URL=.rtc.muziemedia.com

# Optional: Server port (defaults to 3001)
# PORT=3001

# Optional: Environment for cloud features
# ENVIRONMENT=development
